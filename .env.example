# Copy to .env and fill in values
APP_NAME=bagtag.aero
ENVIRONMENT=local

# SQLite — relative path from project root
DATABASE_URL=sqlite+aiosqlite:///./bagtag.db

# JWT — generate with: python -c "import secrets; print(secrets.token_hex(32))"
AUTH_JWT_SECRET=change-me-in-production-use-secrets-token-hex-32
AUTH_JWT_ALG=HS256
AUTH_JWT_EXP_MINUTES=1440

# File uploads
UPLOAD_DIR=static/uploads
MAX_UPLOAD_SIZE_MB=10
